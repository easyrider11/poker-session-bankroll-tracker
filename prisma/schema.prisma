generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id              Int             @id @default(autoincrement())
  name            String
  nickname        String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  lifetimeBuyin   Int             @default(0) @map("lifetime_buyin")
  lifetimeCashout Int             @default(0) @map("lifetime_cashout")
  lifetimeProfit  Int             @default(0) @map("lifetime_profit")
  totalSessions   Int             @default(0) @map("total_sessions")
  sessionPlayers  SessionPlayer[]

  @@index([name])
  @@index([nickname])
  @@map("players")
}

model PokerSession {
  id             Int             @id @default(autoincrement())
  title          String
  sessionDate    DateTime        @map("session_date")
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  finalizedAt    DateTime?       @map("finalized_at")
  sessionPlayers SessionPlayer[]

  @@index([sessionDate])
  @@map("poker_sessions")
}

model SessionPlayer {
  id           Int           @id @default(autoincrement())
  sessionId    Int           @map("session_id")
  playerId     Int           @map("player_id")
  totalBuyin   Int           @default(0) @map("total_buyin")
  totalCashout Int           @default(0) @map("total_cashout")
  profit       Int           @default(0)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  session      PokerSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player       Player        @relation(fields: [playerId], references: [id], onDelete: Restrict)
  buyinRecords BuyinRecord[]

  @@unique([sessionId, playerId])
  @@index([playerId])
  @@index([sessionId])
  @@map("session_players")
}

model BuyinRecord {
  id              Int           @id @default(autoincrement())
  sessionPlayerId Int           @map("session_player_id")
  amount          Int
  createdAt       DateTime      @default(now()) @map("created_at")
  sessionPlayer   SessionPlayer @relation(fields: [sessionPlayerId], references: [id], onDelete: Cascade)

  @@index([sessionPlayerId])
  @@map("buyin_records")
}
