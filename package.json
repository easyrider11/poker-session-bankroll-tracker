{
  "name": "poker-session-bankroll-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "npm run prisma:generate:prod && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --no-file-parallelism",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema prisma/postgres/schema.prisma",
    "preprisma:migrate": "mkdir -p prisma && touch prisma/dev.db",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
